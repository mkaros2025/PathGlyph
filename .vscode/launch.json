{
  "version": "0.2.0",
  "configurations": [
      {
          "name": "Debug PathGlyph",
          "type": "cppdbg",
          "request": "launch",
          "program": "${workspaceFolder}/build/linux/x86_64/debug/PathGlyph",
          "args": [],
          "stopAtEntry": false,
          "cwd": "${workspaceFolder}",
          "environment": [],
          "externalConsole": false,
          "MIMode": "gdb",
          "setupCommands": [
              {
                  "description": "Enable pretty-printing for gdb",
                  "text": "-enable-pretty-printing",
                  "ignoreFailures": true
              }
          ],
          "preLaunchTask": "xmake: build"
      }
  ]
}